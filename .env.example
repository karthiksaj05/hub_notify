# ──────────────────────────────────────────
# Database (shared with backend)
# ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mydatabase

# ──────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@localhost:5672/
MAX_RETRY_ATTEMPTS=4

# ──────────────────────────────────────────
# Email (SMTP)
# Credentials will be shared by instructor
# ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ──────────────────────────────────────────
# Twilio (SMS + WhatsApp)
# Credentials will be shared by instructor
# ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ──────────────────────────────────────────
# Firebase (FCM Push — Android)
# Download service account JSON from Firebase Console
# Then base64-encode it: base64 -i service-account.json
# ──────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ──────────────────────────────────────────
# AWS (APNs Push via SNS — iOS)
# ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SNS_PLATFORM_ARN_IOS=
